    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(SolutionDir)src/contexts/Inference/Synaxis.Inference.Gateway.Api/Synaxis.Inference.Gateway.Api.csproj" />
  </ItemGroup>
